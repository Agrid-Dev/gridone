meta {
  name: create dashboard
  type: http
  seq: 2
}

post {
  url: {{BASE_URL}}/dashboards/
  body: json
  auth: inherit
}

body:json {
  {
    "name": "Acceptance Dashboard",
    "description": "created by bruno"
  }
}

assert {
  res.status: eq 201
  res.body.name: eq Acceptance Dashboard
}

script:post-response {
  bru.setVar("dashboard_id", res.body.id);
}
