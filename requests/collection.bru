auth {
  mode: oauth2
}

auth:oauth2 {
  grant_type: password
  access_token_url: {{BASE_URL}}/auth/token
  username: {{GRIDONE_USERNAME}}
  password: {{GRIDONE_PASSWORD}}
  client_id: gridone
  client_secret:
  scope:
  token_placement: header
  token_header_prefix: Bearer
  auto_fetch_token: true
  auto_refresh_token: true
}
