# API base URL used by the browser.
# - Local backend: http://localhost:8000
# - Remote deployment: use /api together with VITE_DEV_PROXY_TARGET below.
VITE_API_BASE_URL=http://localhost:8000

# Optional: full API base URL of a (remote) backend to proxy /api to in dev.
# Auth cookies are first-party through the proxy, so login works against
# remote deployments. Requires VITE_API_BASE_URL=/api.
# VITE_DEV_PROXY_TARGET=https://my-deployment.example.com/api
