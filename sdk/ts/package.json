{
  "name": "@gridone/sdk",
  "version": "0.1.0",
  "description": "TypeScript client for the Gridone API (browser and Node 18+)",
  "private": true,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "generate-types": "uv run --project ../.. python ../../packages/api/generate_openapi.py && openapi-typescript ../../docs/src/openapi.json -o src/generated/openapi.ts && prettier --write src/generated/openapi.ts",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "smoke": "tsx --env-file-if-exists=.env scripts/smoke.ts",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier .",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^24.10.9",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.1.0",
    "jiti": "^2.6.1",
    "openapi-typescript": "7.13.0",
    "prettier": "3.8.1",
    "tsup": "^8.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vitest": "^4.0.18"
  }
}
