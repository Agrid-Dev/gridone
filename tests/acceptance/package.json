{
  "name": "gridone-acceptance-tests",
  "version": "0.0.0",
  "description": "Black-box acceptance tests running against the Gridone docker image through @gridone/sdk",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "stack:up": "docker compose up --build --wait",
    "stack:down": "docker compose down -v",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "lint": "eslint suites/ lib/ setup/",
    "lint:fix": "eslint suites/ lib/ setup/ --fix",
    "format": "prettier .",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@gridone/sdk": "file:../../sdk/ts",
    "@types/node": "^24.10.9",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.1.0",
    "jiti": "^2.6.1",
    "prettier": "3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vitest": "^4.0.18"
  }
}
